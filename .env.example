# Mediajedi Hedge Fund — secrets template.
# Copy to .env and fill in. The real .env is gitignored.

# Financial Modeling Prep (Premium tier) — fundamentals + ratios
FMP_API_KEY=

# Anthropic — Layer 3 AI analysis
ANTHROPIC_API_KEY=

# Alpaca PAPER trading (dedicated account for this fund; do NOT reuse the day trader's)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# SEC EDGAR requires a real contact email in the User-Agent header
SEC_USER_AGENT_EMAIL=

# SMTP notifications (optional)
SMTP_PASSWORD=

# Dashboard auth (optional — set to enable the login screen + TOTP 2FA).
# Generate with: python3 -m scripts.setup_auth <username>
AUTH_USER=
AUTH_PASSWORD_HASH=
AUTH_TOTP_SECRET=
